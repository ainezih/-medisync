# ─────────────────────────────────────────────────────────────────────────────
#  .env.example  —  copy to .env.local and fill in.
#
#  Clinica — patient management for small clinics & private practices.
#
#  The guided setup ("/setup" in Claude Code) does this FOR you: it asks which
#  integrations you want, collects each key, and writes .env.local.
#
#  Every key here is OPTIONAL. With none set, the app runs in DEMO MODE with
#  realistic (FICTIONAL) patient & appointment data so you can see it immediately.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (database & auth) ───────────────────────────────────────────────
# Patients, appointments, charts. https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Twilio (SMS appointment reminders) ───────────────────────────────────────
# https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── PayTR (billing & card payments) ──────────────────────────────────────────
# https://www.paytr.com/magaza/api-bilgileri
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# ── Daily (telehealth video visits) ──────────────────────────────────────────
# https://dashboard.daily.co/developers
DAILY_API_KEY=
